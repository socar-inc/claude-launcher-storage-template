{
  "mcpServers": {
    "atlassian": {
      "type": "stdio",
      "command": "mcp-atlassian",
      "env": {
        "CONFLUENCE_URL": "https://socarcorp.atlassian.net",
        "CONFLUENCE_USERNAME": "${ATLASSIAN_EMAIL}",
        "CONFLUENCE_API_TOKEN": "${ATLASSIAN_API_TOKEN}",
        "JIRA_URL": "https://socarcorp.atlassian.net",
        "JIRA_USERNAME": "${ATLASSIAN_EMAIL}",
        "JIRA_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      }
    },
    "datadog": {
      "type": "http",
      "url": "https://mcp.datadoghq.com/api/unstable/mcp-server/mcp",
      "headers": {
        "Authorization": "Bearer ${DATADOG_ACCESS_TOKEN}"
      }
    },
    "figma": {
      "type": "stdio",
      "command": "figma-developer-mcp",
      "env": { "FIGMA_API_KEY": "${FIGMA_ACCESS_TOKEN}" }
    }
  }
}
